@startuml
title Feature 007. Public-content ER изменения: benefit-лендинги, referral-коды и conversion events

entity public_benefit_landing {
  * id : uuid
  --
  landing_type : varchar
  route_path : varchar
  default_variant : varchar
  campaign_id : varchar
  seo_title_key : varchar
  seo_description_key : varchar
  published : boolean
}

entity public_benefit_landing_block {
  * id : uuid
  --
  landing_id : uuid
  block_key : varchar
  block_type : varchar
  variant : varchar
  title_key : varchar
  body_key : varchar
  payload : jsonb
  sort_order : int
  display_condition : varchar
}

entity public_benefit_cta {
  * id : uuid
  --
  block_id : uuid
  cta_type : varchar
  label_key : varchar
  target_route : varchar
  preserve_referral_context : boolean
  sort_order : int
}

entity public_referral_code {
  * id : uuid
  --
  code : varchar
  sponsor_public_name_key : varchar
  status : varchar
  campaign_id : varchar
  valid_from : timestamptz
  valid_to : timestamptz
}

entity public_landing_conversion_event {
  * id : uuid
  --
  landing_type : varchar
  variant : varchar
  referral_code : varchar
  campaign_id : varchar
  cta_type : varchar
  route_path : varchar
  occurred_at : timestamptz
  anonymous_session_id : varchar
}

public_benefit_landing ||--o{ public_benefit_landing_block
public_benefit_landing_block ||--o{ public_benefit_cta
public_referral_code ||--o{ public_landing_conversion_event : referral_code
public_benefit_landing ||--o{ public_landing_conversion_event : landing_type
@enduml
