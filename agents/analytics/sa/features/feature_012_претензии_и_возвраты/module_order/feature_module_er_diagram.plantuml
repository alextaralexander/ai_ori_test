@startuml
title Feature 012 - изменения ER для module_order
entity order_claim {
  * claim_id : string
  --
  owner_user_id : string
  order_number : string
  claim_status : enum
  requested_resolution : enum
  approved_resolution : enum
  refund_amount : decimal
  currency_code : string
  partner_impact : boolean
  created_at : timestamp
  updated_at : timestamp
}
entity order_claim_item {
  * claim_item_id : string
  --
  claim_id : string
  product_code : string
  sku : string
  product_name : string
  quantity : integer
  unit_price : decimal
  requested_resolution : enum
  approved_resolution : enum
  item_status : enum
  reason_mnemo : string
}
entity order_claim_event {
  * event_id : string
  --
  claim_id : string
  event_type : string
  public_status : string
  source_system : string
  description_mnemo : string
  occurred_at : timestamp
}
entity order_claim_comment {
  * comment_id : string
  --
  claim_id : string
  author_role : string
  visibility : enum
  message_mnemo : string
  created_at : timestamp
}
entity order_claim_attachment {
  * attachment_id : string
  --
  claim_id : string
  file_name : string
  content_type : string
  size_bytes : long
  public_url_token : string
}
order_claim ||--o{ order_claim_item
order_claim ||--o{ order_claim_event
order_claim ||--o{ order_claim_comment
order_claim ||--o{ order_claim_attachment
@enduml