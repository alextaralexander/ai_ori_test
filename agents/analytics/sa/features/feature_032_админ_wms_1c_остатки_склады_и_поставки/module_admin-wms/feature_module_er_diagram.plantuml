@startuml
title Feature 032 / module admin-wms ER diagram

entity "admin_wms_warehouse" as warehouse {
  * warehouse_id : uuid <<PK>>
  --
  warehouse_code : varchar(80) <<UK>>
  name : varchar(255)
  warehouse_type : varchar(40)
  region_code : varchar(40)
  status : varchar(40)
  source_system : varchar(40)
  external_warehouse_id : varchar(120)
  sales_channels : jsonb
  receiving_sla_hours : int
  shipping_sla_hours : int
  sync_schedule : varchar(120)
  version : bigint
  created_at : timestamptz
  updated_at : timestamptz
}

entity "admin_wms_stock_item" as stock {
  * stock_item_id : uuid <<PK>>
  --
  warehouse_id : uuid <<FK>>
  product_id : varchar(80)
  sku : varchar(80)
  catalog_period_code : varchar(80)
  channel_code : varchar(40)
  physical_qty : numeric(19,4)
  sellable_qty : numeric(19,4)
  reserved_qty : numeric(19,4)
  blocked_qty : numeric(19,4)
  inbound_qty : numeric(19,4)
  backorder_qty : numeric(19,4)
  availability_status : varchar(40)
  last_sync_at : timestamptz
  version : bigint
}

entity "admin_wms_availability_rule" as rule {
  * rule_id : uuid <<PK>>
  --
  warehouse_id : uuid <<FK>>
  sku : varchar(80)
  channel_code : varchar(40)
  policy : varchar(40)
  reason_code : varchar(80)
  active_from : timestamptz
  active_to : timestamptz
  version : bigint
}

entity "admin_wms_supply" as supply {
  * supply_id : uuid <<PK>>
  --
  supply_code : varchar(80) <<UK>>
  warehouse_id : uuid <<FK>>
  source_system : varchar(40)
  supplier_code : varchar(80)
  external_document_id : varchar(120)
  status : varchar(40)
  expected_at : timestamptz
  arrived_at : timestamptz
  idempotency_key : varchar(120)
  version : bigint
}

entity "admin_wms_supply_line" as supply_line {
  * supply_line_id : uuid <<PK>>
  --
  supply_id : uuid <<FK>>
  external_line_id : varchar(120)
  sku : varchar(80)
  planned_qty : numeric(19,4)
  accepted_qty : numeric(19,4)
  damaged_qty : numeric(19,4)
  shortage_qty : numeric(19,4)
  surplus_qty : numeric(19,4)
  reason_code : varchar(80)
}

entity "admin_wms_stock_movement" as movement {
  * movement_id : uuid <<PK>>
  --
  warehouse_id : uuid <<FK>>
  sku : varchar(80)
  movement_type : varchar(40)
  quantity_delta : numeric(19,4)
  source_document_type : varchar(40)
  source_document_id : varchar(120)
  external_document_id : varchar(120)
  idempotency_key : varchar(120)
  correlation_id : varchar(120)
  occurred_at : timestamptz
}

entity "admin_wms_reservation" as reservation {
  * reservation_id : uuid <<PK>>
  --
  order_id : varchar(80)
  warehouse_id : uuid <<FK>>
  sku : varchar(80)
  quantity : numeric(19,4)
  status : varchar(40)
  hold_expires_at : timestamptz
  idempotency_key : varchar(120) <<UK>>
  version : bigint
}

entity "admin_wms_sync_run" as sync_run {
  * sync_run_id : uuid <<PK>>
  --
  source_system : varchar(40)
  warehouse_id : uuid <<FK>>
  sku_filter : varchar(80)
  document_type : varchar(40)
  status : varchar(40)
  processed_count : int
  duplicate_count : int
  error_count : int
  quarantined_count : int
  correlation_id : varchar(120)
  started_at : timestamptz
  completed_at : timestamptz
}

entity "admin_wms_sync_message" as sync_message {
  * sync_message_id : uuid <<PK>>
  --
  sync_run_id : uuid <<FK>>
  source_system : varchar(40)
  external_document_id : varchar(120)
  external_line_id : varchar(120)
  idempotency_key : varchar(120)
  message_status : varchar(40)
  payload_checksum : varchar(128)
  reason_code : varchar(80)
  affected_sku : varchar(80)
  retry_count : int
  received_at : timestamptz
}

entity "admin_wms_discrepancy" as discrepancy {
  * discrepancy_id : uuid <<PK>>
  --
  warehouse_id : uuid <<FK>>
  sku : varchar(80)
  supply_id : uuid <<FK>>
  discrepancy_type : varchar(40)
  severity : varchar(40)
  quantity_delta : numeric(19,4)
  status : varchar(40)
  reason_code : varchar(80)
  owner_user_id : uuid
  correlation_id : varchar(120)
}

entity "admin_wms_audit_event" as audit {
  * audit_event_id : uuid <<PK>>
  --
  actor_user_id : uuid
  action_code : varchar(80)
  entity_type : varchar(80)
  entity_id : varchar(80)
  old_value : jsonb
  new_value : jsonb
  reason_code : varchar(80)
  idempotency_key : varchar(120)
  correlation_id : varchar(120)
  occurred_at : timestamptz
}

warehouse ||--o{ stock
warehouse ||--o{ rule
warehouse ||--o{ supply
supply ||--o{ supply_line
warehouse ||--o{ movement
warehouse ||--o{ reservation
warehouse ||--o{ sync_run
sync_run ||--o{ sync_message
warehouse ||--o{ discrepancy
supply ||--o{ discrepancy

@enduml
