@startuml
title Module catalog. Полная ER-диаграмма на feature 006

entity "catalog_category" as category {
  * id : uuid
  --
  * slug : varchar(120)
  * name_i18n_key : varchar(160)
  parent_id : uuid
  * display_order : int
  * published : boolean
}

entity "catalog_product" as product {
  * id : uuid
  --
  * sku : varchar(64)
  * slug : varchar(160)
  * name_i18n_key : varchar(180)
  * short_description_i18n_key : varchar(220)
  * category_id : uuid
  * image_url : varchar(500)
  * brand : varchar(128)
  * volume_label : varchar(64)
  * campaign_code : varchar(40)
  * base_price : decimal(12,2)
  promo_price : decimal(12,2)
  * currency : char(3)
  * availability_status : varchar(40)
  available_quantity : int
  * min_order_quantity : int
  * max_order_quantity : int
  * published : boolean
  * popular_rank : int
  * created_at : timestamptz
}

entity "catalog_product_detail" as detail {
  * product_id : uuid
  --
  * full_description_i18n_key : varchar(220)
  usage_instructions_i18n_key : varchar(220)
  ingredients_i18n_key : varchar(220)
  characteristics_json : text
}

entity "catalog_product_media" as media {
  * id : uuid
  --
  * product_id : uuid
  * media_type : varchar(40)
  * url : varchar(1000)
  * alt_text_i18n_key : varchar(220)
  * display_order : int
  * primary_media : boolean
}

entity "catalog_product_attachment" as attachment {
  * id : uuid
  --
  * product_id : uuid
  * title_i18n_key : varchar(220)
  * document_type : varchar(80)
  * url : varchar(1000)
  * display_order : int
}

entity "catalog_product_recommendation" as recommendation {
  * id : uuid
  --
  * product_id : uuid
  * recommended_product_id : uuid
  * recommendation_type : varchar(40)
  * display_order : int
}

entity "catalog_product_tag" as tag {
  * product_id : uuid
  * tag_code : varchar(80)
}

entity "catalog_product_promo" as promo {
  * product_id : uuid
  * promo_code : varchar(80)
}

entity "catalog_cart_item" as cart_item {
  * id : uuid
  --
  * user_context_id : varchar(120)
  * audience : varchar(40)
  * product_id : uuid
  * quantity : int
  * partner_context : boolean
  * source : varchar(40)
  * created_at : timestamptz
}

entity "catalog_digital_issue" as digital_issue {
  * id : uuid
  --
  * issue_code : varchar(64)
  * title_i18n_key : varchar(220)
  * period_type : varchar(32)
  * period_start : date
  * period_end : date
  * publication_status : varchar(32)
  preview_allowed_from : timestamptz
  * display_order : int
  * created_at : timestamptz
  * updated_at : timestamptz
}

entity "catalog_digital_page" as digital_page {
  * id : uuid
  --
  * issue_id : uuid
  * page_number : int
  * image_url : varchar(1000)
  thumbnail_url : varchar(1000)
  * width_px : int
  * height_px : int
  * created_at : timestamptz
}

entity "catalog_digital_material" as digital_material {
  * id : uuid
  --
  * issue_id : uuid
  * material_type : varchar(32)
  * title_i18n_key : varchar(220)
  * file_url : varchar(1000)
  file_size_bytes : bigint
  * publication_status : varchar(32)
  * allow_download : boolean
  * allow_share : boolean
  * display_order : int
  * created_at : timestamptz
  * updated_at : timestamptz
}

entity "catalog_digital_page_hotspot" as digital_hotspot {
  * id : uuid
  --
  * page_id : uuid
  * product_id : uuid
  * x_percent : decimal(6,3)
  * y_percent : decimal(6,3)
  * width_percent : decimal(6,3)
  * height_percent : decimal(6,3)
  * display_order : int
}

entity "catalog_digital_visibility" as digital_visibility {
  * id : uuid
  --
  * issue_id : uuid
  material_id : uuid
  * role_code : varchar(64)
  * can_preview : boolean
  * can_download : boolean
  * can_share : boolean
}

category ||--o{ category : parent
category ||--o{ product : contains
product ||--|| detail : has
product ||--o{ media : has
product ||--o{ attachment : has
product ||--o{ recommendation : recommends
product ||--o{ recommendation : recommended_as
product ||--o{ tag : has
product ||--o{ promo : has
product ||--o{ cart_item : added_to
digital_issue ||--o{ digital_page : pages
digital_issue ||--o{ digital_material : materials
digital_issue ||--o{ digital_visibility : issue_visibility
digital_material ||--o{ digital_visibility : material_visibility
digital_page ||--o{ digital_hotspot : hotspots
product ||--o{ digital_hotspot : linked_from_catalogue
@enduml
