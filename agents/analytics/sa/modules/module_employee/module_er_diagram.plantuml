@startuml
title Module employee - full ER overview through feature 023

entity employee_support_session {
  * support_session_id : uuid
  actor_user_id : varchar(64)
  target_customer_id : varchar(64)
  target_partner_id : varchar(64)
  support_reason_code : varchar(64)
  status : varchar(32)
  started_at : timestamptz
  closed_at : timestamptz
}

entity employee_operator_order {
  * operator_order_id : uuid
  support_session_id : uuid
  checkout_id : varchar(64)
  order_number : varchar(64)
  cart_type : varchar(32)
  payment_status : varchar(32)
  delivery_status : varchar(32)
  idempotency_key : varchar(128)
  created_at : timestamptz
}

entity employee_support_action {
  * support_action_id : uuid
  support_session_id : uuid
  order_number : varchar(64)
  action_type : varchar(64)
  payload_json : jsonb
  created_at : timestamptz
}

entity employee_audit_event {
  * audit_event_id : uuid
  actor_user_id : varchar(64)
  action_type : varchar(64)
  target_entity_type : varchar(64)
  target_entity_id : varchar(128)
  correlation_id : varchar(128)
  occurred_at : timestamptz
}

entity employee_order_history_snapshot {
  * order_snapshot_id : uuid
  order_id : varchar(64)
  order_number : varchar(64)
  customer_id : varchar(64)
  partner_id : varchar(64)
  campaign_code : varchar(32)
  order_status : varchar(32)
  payment_status : varchar(32)
  delivery_status : varchar(32)
  total_amount : numeric(19,2)
  problem_flags_json : jsonb
  updated_at : timestamptz
}

entity employee_order_history_item_snapshot {
  * item_snapshot_id : uuid
  order_snapshot_id : uuid
  sku : varchar(64)
  product_name : varchar(255)
  quantity : integer
  unit_price : numeric(19,2)
  bonus_points : numeric(19,2)
}

entity employee_order_history_audit_event {
  * audit_event_id : uuid
  order_id : varchar(64)
  actor_user_id : varchar(64)
  action_type : varchar(64)
  support_reason_code : varchar(64)
  occurred_at : timestamptz
}

entity employee_claim_case {
  * claim_id : uuid
  claim_number : varchar(64)
  order_number : varchar(64)
  customer_id : varchar(64)
  partner_id : varchar(64)
  status : varchar(32)
  sla_due_at : timestamptz
  public_reason_mnemonic : varchar(128)
  idempotency_key : varchar(128)
}

entity employee_claim_item {
  * claim_item_id : uuid
  claim_id : uuid
  sku : varchar(64)
  quantity : integer
  problem_type : varchar(64)
  compensation_amount : numeric(19,2)
}

entity employee_claim_attachment {
  * attachment_id : uuid
  claim_id : uuid
  file_reference_id : varchar(128)
  filename : varchar(255)
  access_policy : varchar(64)
}

entity employee_claim_route_task {
  * route_task_id : uuid
  claim_id : uuid
  task_type : varchar(64)
  status : varchar(32)
  due_at : timestamptz
}

entity employee_claim_audit_event {
  * audit_event_id : uuid
  claim_id : uuid
  actor_user_id : varchar(64)
  action_type : varchar(64)
  correlation_id : varchar(128)
  occurred_at : timestamptz
}

entity employee_partner_card_audit {
  * audit_event_id : uuid
  actor_user_id : varchar(128)
  support_reason_code : varchar(64)
  target_entity_type : varchar(64)
  partner_id : varchar(64)
  person_number : varchar(64)
  correlation_id : varchar(128)
  occurred_at : timestamptz
}

entity employee_partner_report_snapshot {
  * report_snapshot_id : uuid
  partner_id : varchar(64)
  person_number : varchar(64)
  campaign_code : varchar(32)
  total_orders : integer
  total_amount : numeric(19,2)
  personal_volume : numeric(19,2)
  group_volume : numeric(19,2)
  generated_at : timestamptz
}

entity employee_profile_settings {
  * employee_id : varchar(64)
  display_name : varchar(255)
  job_title : varchar(128)
  department_code : varchar(64)
  preferred_language : varchar(16)
  timezone : varchar(64)
  employee_status : varchar(32)
  version : bigint
}

entity employee_contact {
  * contact_id : uuid
  employee_id : varchar(64)
  contact_type : varchar(32)
  contact_value_encrypted : text
  masked_value : varchar(128)
  verification_status : varchar(32)
}

entity employee_address {
  * address_id : uuid
  employee_id : varchar(64)
  address_type : varchar(32)
  region_code : varchar(32)
  city : varchar(128)
  address_line : varchar(512)
  active_flag : boolean
}

entity employee_document_metadata {
  * document_id : uuid
  employee_id : varchar(64)
  document_type : varchar(64)
  masked_number : varchar(128)
  verification_status : varchar(32)
  linked_policy_code : varchar(96)
  file_reference_id : varchar(128)
}

entity employee_security_event {
  * security_event_id : uuid
  employee_id : varchar(64)
  event_type : varchar(64)
  risk_level : varchar(32)
  metadata_json : jsonb
  occurred_at : timestamptz
}

entity employee_elevated_request {
  * elevated_request_id : uuid
  employee_id : varchar(64)
  policy_code : varchar(96)
  reason_code : varchar(64)
  target_scope : varchar(256)
  status : varchar(48)
  requested_at : timestamptz
  decided_by : varchar(64)
}

entity employee_elevated_session {
  * elevated_session_id : uuid
  elevated_request_id : uuid
  employee_id : varchar(64)
  policy_code : varchar(96)
  target_scope : varchar(256)
  status : varchar(32)
  started_at : timestamptz
  expires_at : timestamptz
  correlation_id : varchar(128)
}

entity employee_elevated_audit {
  * audit_event_id : uuid
  actor_user_id : varchar(64)
  target_employee_id : varchar(64)
  elevated_request_id : uuid
  elevated_session_id : uuid
  action_code : varchar(96)
  correlation_id : varchar(128)
  occurred_at : timestamptz
}

employee_support_session ||--o{ employee_operator_order : support_session_id
employee_support_session ||--o{ employee_support_action : support_session_id
employee_order_history_snapshot ||--o{ employee_order_history_item_snapshot : order_snapshot_id
employee_claim_case ||--o{ employee_claim_item : claim_id
employee_claim_case ||--o{ employee_claim_attachment : claim_id
employee_claim_case ||--o{ employee_claim_route_task : claim_id
employee_claim_case ||--o{ employee_claim_audit_event : claim_id
employee_profile_settings ||--o{ employee_contact : employee_id
employee_profile_settings ||--o{ employee_address : employee_id
employee_profile_settings ||--o{ employee_document_metadata : employee_id
employee_profile_settings ||--o{ employee_security_event : employee_id
employee_profile_settings ||--o{ employee_elevated_request : employee_id
employee_elevated_request ||--o| employee_elevated_session : request
employee_document_metadata ||--o{ employee_elevated_request : linked_document
employee_elevated_request ||--o{ employee_elevated_audit : request_audit
employee_elevated_session ||--o{ employee_elevated_audit : session_audit

@enduml