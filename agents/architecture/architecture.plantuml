@startuml
title Best Ori Gin monolith architecture with employee module
package "frontend/monolith apps/web-shell" {
  [PublicShell]
  [Catalog UI]
  [Cart UI]
  [Order UI]
  [Partner UI]
  [EmployeeWorkspace UI]
}
package "backend/monolith/monolith-app" {
  [public-content]
  [catalog]
  [cart]
  [order]
  [profile]
  [bonus-wallet]
  [partner-reporting]
  [mlm-structure]
  [partner-office]
  [employee]
}
database "Postgres/Liquibase XML" as db
cloud "WMS/1C" as wms
cloud "Payment" as pay
cloud "Delivery" as delivery
cloud "Bonus engine" as bonus

[EmployeeWorkspace UI] --> [employee] : /api/employee
[employee] --> [order]
[employee] --> [cart]
[employee] --> [profile]
[employee] --> [partner-reporting]
[order] --> pay
[order] --> delivery
[order] --> wms
[bonus-wallet] --> bonus
[employee] --> db : support audit target tables
@enduml