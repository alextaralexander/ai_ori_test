@startuml
skinparam componentStyle rectangle
component "web-shell frontend" as Web
component "public-content" as PublicContent
component "catalog" as Catalog
component "cart" as Cart
component "order" as Order
component "profile" as Profile
component "bonus-wallet" as Bonus
component "partner-onboarding" as Onboarding
component "partner-reporting" as Reporting
component "mlm-structure" as MLM
component "WMS/1C" as WMS
component "Payment" as Payment
component "Delivery" as Delivery
Web --> PublicContent : HTTP JSON
Web --> Catalog : HTTP JSON
Web --> Cart : HTTP JSON
Web --> Order : HTTP JSON
Web --> Profile : HTTP JSON
Web --> Bonus : HTTP JSON
Web --> Onboarding : HTTP JSON
Web --> Reporting : HTTP JSON
Web --> MLM : HTTP JSON /api/mlm-structure
MLM --> Order : route/link context for partner orders
MLM --> Bonus : route/link context for bonus wallet
MLM --> Reporting : route/link context for commissions and reports
Order --> Payment : payment API
Order --> WMS : stock/reservation API
Order --> Delivery : delivery API
@enduml