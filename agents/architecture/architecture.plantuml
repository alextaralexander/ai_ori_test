@startuml
title Best Ori Gin monolith architecture through feature 025

package "frontend/monolith apps/web-shell" {
  [I18nProvider]
  [NotificationProvider]
  [OfflineStatusProvider]
  [AnalyticsProvider]
  [ConsentPanel]
  [AnalyticsDiagnostics UI]
  [AuthProvider]
  [RoleRouter]
  [ActivePartnerSwitcher]
  [ImpersonationPanel]
  [PublicShell]
  [Catalog UI]
  [Cart UI]
  [Order UI]
  [Partner UI]
  [EmployeeWorkspace UI]
  [EmployeeOrderHistory UI]
  [EmployeeClaims UI]
  [EmployeePartnerCard UI]
  [EmployeePartnerReport UI]
  [EmployeeProfileSettings UI]
  [EmployeeSuperUser UI]
}

package "backend/monolith/monolith-app" {
  [public-content]
  [auth]
  [catalog]
  [cart]
  [order]
  [profile]
  [authorization]
  [bonus-wallet]
  [partner-reporting]
  [mlm-structure]
  [partner-office]
  [employee]
  [platform-experience]
}

database "Postgres/Liquibase XML" as db
cloud "S3/MinIO documents" as s3
cloud "WMS/1C" as wms
cloud "Payment" as pay
cloud "Delivery" as delivery
cloud "Bonus engine" as bonus
cloud "Claims" as claims
cloud "Yandex Metrika" as metrika
cloud "Mindbox" as mindbox
cloud "Hybrid Pixel" as hybrid

[I18nProvider] --> [platform-experience] : HTTP/JSON /api/platform-experience/diagnostics/i18n-missing-keys
[NotificationProvider] --> [platform-experience] : HTTP/JSON /api/platform-experience/notification/preferences
[OfflineStatusProvider] --> [auth] : HTTP/JSON session check after reconnect
[AnalyticsProvider] --> [platform-experience] : HTTP/JSON /runtime-config, /consent/preferences, /diagnostics/analytics-events
[ConsentPanel] --> [platform-experience] : HTTP/JSON /api/platform-experience/consent/preferences
[AnalyticsDiagnostics UI] --> [platform-experience] : HTTP/JSON /api/platform-experience/diagnostics/summary
[EmployeeWorkspace UI] --> [employee] : HTTP/JSON /api/employee/workspace, /operator-orders, /order-support
[EmployeeOrderHistory UI] --> [employee] : HTTP/JSON /api/employee/order-history, /order-history/{orderId}
[EmployeeClaims UI] --> [employee] : HTTP/JSON /api/employee/submit-claim, /claims, /claims/{claimId}, /transitions
[EmployeePartnerCard UI] --> [employee] : HTTP/JSON /api/employee/partner-card, /partner-card/{partnerId}
[EmployeePartnerReport UI] --> [employee] : HTTP/JSON /api/employee/report/order-history
[EmployeeProfileSettings UI] --> [employee] : HTTP/JSON /api/employee/profile-settings/*
[EmployeeSuperUser UI] --> [employee] : HTTP/JSON /api/employee/super-user/*
[AuthProvider] --> [auth] : HTTP/JSON /api/auth/session, /test-login, /invitation-code
[RoleRouter] --> [auth] : HTTP/JSON /api/auth/session/route-access
[ActivePartnerSwitcher] --> [auth] : HTTP/JSON /api/auth/partners/search, /partners/active
[ImpersonationPanel] --> [auth] : HTTP/JSON /api/auth/impersonation/*

[auth] --> [authorization] : role, route policy, MFA/elevated policy checks
[auth] --> [employee] : elevatedSessionId validation for controlled impersonation
[auth] --> db : auth sessions, roles, route policies, active partner, impersonation and audit
[platform-experience] --> db : consent preferences, notification preferences, runtime config snapshots and diagnostics
[AnalyticsProvider] --> metrika : consent-aware pageview/conversion events
[AnalyticsProvider] --> mindbox : consent-aware marketing/conversion events
[AnalyticsProvider] --> hybrid : consent-aware pixel events
[employee] --> [authorization] : role, scope, MFA, locks, supervisor checks
[employee] --> [order] : order read links and elevated operation context
[employee] --> [cart] : active cart/operator order context
[employee] --> [profile] : masked customer, partner and employee profile data
[employee] --> [partner-reporting] : partner KPI/report links
[employee] --> [bonus-wallet] : partner bonus balance and volume links
[employee] --> claims : claim ids, claim creation and claim deep links
[employee] --> pay : payment events, refund and compensation tasks
[employee] --> wms : WMS batch, fulfillment and warehouse review tasks
[employee] --> delivery : delivery tracking links and delayed delivery signals
[employee] --> s3 : employee document fileReferenceId verification
[employee] --> db : employee support/order-history/claims/partner/profile/elevated read models and audit tables

[order] --> pay : payment protocol
[order] --> delivery : delivery protocol
[order] --> wms : fulfillment protocol
[bonus-wallet] --> bonus : bonus protocol
[partner-office] --> wms : supply and acceptance protocol

@enduml
