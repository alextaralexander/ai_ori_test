@startuml
title Best Ori Gin target architecture after feature 014
package "Frontend web-shell" {
  [PublicShell]
  [ProfileSettingsView]
  [BonusWalletView]
  [OrderCheckoutView]
  [OrderHistoryView]
  [OrderClaimsView]
  [i18n resources]
}
package "Backend monolith" {
  package "module_profile" {
    [Profile API]
    [ProfileReadinessService]
    [ProfileAuditService]
  }
  package "module_bonus-wallet" {
    [Bonus Wallet API]
    [Wallet Ledger Service]
    [Wallet Limit Service]
  }
  package "module_order" {
    [Checkout API]
    [Order history API]
    [Order claims API]
    [OrderClaimService]
  }
  package "module_catalog" {
    [Catalog API]
  }
  package "module_public-content" {
    [Public content API]
  }
}
package "External systems" {
  [Payment]
  [Warehouse and logistics]
  [S3 or MinIO attachments]
}
[ProfileSettingsView] --> [Profile API]
[BonusWalletView] --> [Bonus Wallet API]
[Profile API] --> [ProfileReadinessService]
[Profile API] --> [ProfileAuditService]
[ProfileSettingsView] --> [i18n resources]
[Checkout API] --> [ProfileReadinessService]
[Checkout API] --> [Wallet Limit Service]
[Order claims API] --> [ProfileReadinessService]
[Order claims API] --> [Wallet Ledger Service]
[OrderClaimsView] --> [Order claims API]
[Order claims API] --> [OrderClaimService]
[OrderClaimService] --> [Order history API]
[OrderClaimService] --> [Payment]
[OrderClaimService] --> [Warehouse and logistics]
[OrderClaimService] --> [S3 or MinIO attachments]
[OrderClaimsView] --> [i18n resources]
[BonusWalletView] --> [i18n resources]
[Wallet Ledger Service] --> [Order history API]
@enduml
