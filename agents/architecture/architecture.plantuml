@startuml
title Best Ori Gin. Архитектура платформы на feature 008

skinparam componentStyle rectangle

actor "Гость" as Guest
actor "Покупатель" as Customer
actor "Партнер" as Partner
actor "Контент-менеджер" as ContentManager
actor "Маркетинг-менеджер" as MarketingManager
actor "Каталожный менеджер" as CatalogManager
actor "Редактор документов" as LegalEditor
actor "Приглашенный партнер" as InvitedPartner

component "frontend/public-web\nReact + TypeScript + Ant Design" as PublicWeb
component "backend/monolith/public-content\nSpring Boot module\npages, navigation, news, content, offers, FAQ, info, documents, benefit landings" as PublicContent
component "backend/monolith/catalog\nSpring Boot module\nsearch, product cards, cart quick add, digital catalogues" as Catalog
component "backend/monolith/partner-onboarding\nSpring Boot module\nregistration, invites, activation, sponsor cabinet" as PartnerOnboarding
database "PostgreSQL\npublic-content schema\nCMS pages, news, offers, FAQ, info, documents, benefit landings, referral, conversions" as PublicDb
database "PostgreSQL\ncatalog schema\ncategories, products, tags, promos, cart items, digital issues" as CatalogDb
database "PostgreSQL\npartner-onboarding schema\ninvites, applications, activation tokens, partner profiles, referral links, events" as PartnerOnboardingDb
cloud "S3/MinIO\ncatalog PDF materials" as CatalogStorage
cloud "CRM / marketing systems\nregistration lead events" as CrmSystem
component "CMS admin контур\nбудущие админ-фичи" as CmsAdmin
component "Auth/Profile контур\nбудущие фичи" as AuthProfile
component "Cart/Order контур\nбудущие фичи" as CartOrder
component "Partner контур\nбудущие фичи" as PartnerArea

Guest --> PublicWeb : HTTPS /, /home, /community, /news, /content/:id, /offer/:id, /FAQ, /info/:section, /documents/:type, benefit routes, invite routes, /products/digital-catalogue-current, /products/digital-catalogue-next, /search, /product/:code
Customer --> PublicWeb : HTTPS публичные, клиентские маршруты, digital catalogues, /search и /product/:code
Partner --> PublicWeb : HTTPS публичные, партнерские маршруты, referral benefit routes, sponsor cabinet, digital catalogues, /search и /product/:code
InvitedPartner --> PublicWeb : HTTPS /invite/partners-activation
ContentManager --> CmsAdmin : HTTPS управление контентом
MarketingManager --> CmsAdmin : HTTPS управление benefit-блоками, A/B-вариантами и CTA
CatalogManager --> CmsAdmin : HTTPS управление товарами, кампаниями и цифровыми выпусками
LegalEditor --> CmsAdmin : HTTPS версии документов и архив

PublicWeb --> PublicContent : REST pages, navigation, entry-points
PublicWeb --> PublicContent : REST news, content, offers
PublicWeb --> PublicContent : REST faq, info, documents
PublicWeb --> PublicContent : REST benefit landing payload, referral status, conversion events
PublicWeb --> PartnerOnboarding : REST invite validation, registration application, activation, sponsor cabinet
PublicWeb --> Catalog : REST search, filters, product cards, recommendations
PublicWeb --> Catalog : REST product detail, media, attachments, availability
PublicWeb --> Catalog : REST cart quick add from search/product card
PublicWeb --> Catalog : REST digital catalogues, PDF actions, product hotspots
PublicContent --> PublicDb : JDBC / Liquibase XML target model
Catalog --> CatalogDb : JDBC / Liquibase XML target model
PartnerOnboarding --> PartnerOnboardingDb : JDBC / Liquibase XML target model
Catalog --> CatalogStorage : S3/MinIO temporary URL for PDF download/share
PartnerOnboarding --> CrmSystem : REST/event registration lead events and retry
CmsAdmin --> PublicContent : REST управление CMS-контентом
CmsAdmin --> Catalog : REST управление каталогом и цифровыми выпусками
PublicWeb --> AuthProfile : REST вход, профиль, audience
PublicContent ..> Catalog : productRef / route references to /search
PublicContent ..> PartnerOnboarding : referral context handoff через frontend route
PartnerOnboarding ..> AuthProfile : activation creates login/profile handoff
PartnerOnboarding ..> PartnerArea : initial partner profile and referral link handoff
Catalog ..> CartOrder : future order/cart integration boundary and checkout handoff
PublicWeb --> PartnerArea : route navigation в партнерский офис

@enduml
