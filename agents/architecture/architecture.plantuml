@startuml
title Best Ori Gin monolith architecture through feature 039

package "frontend/monolith apps/web-shell" {
  [PublicShell]
  [Catalog UI]
  [Cart UI]
  [Checkout Delivery UI]
  [Order Tracking UI]
  [Pickup Owner Cabinet UI]
  [EmployeeWorkspace UI]
  [AdminOrders UI]
  [AdminService UI]
  [AdminPlatform UI]
  [AdminBonus UI]
  [AdminFulfillment UI]
  [I18nProvider]
  [NotificationProvider]
  [OfflineStatusProvider]
  [AnalyticsProvider]
  [AuthProvider]
  [RoleRouter]
}

package "backend/monolith/monolith-app" {
  [public-content]
  [auth]
  [authorization]
  [catalog]
  [cart]
  [order]
  [delivery]
  [profile]
  [bonus-wallet]
  [partner-office]
  [employee]
  [platform-experience]
  [admin-rbac]
  [admin-cms]
  [admin-referral]
  [admin-pim]
  [admin-catalog]
  [admin-pricing]
  [admin-wms]
  [admin-order]
  [admin-service]
  [admin-identity]
  [admin-platform]
  [admin-bonus]
  [admin-fulfillment]
}

database "Postgres / Liquibase XML" as db
cloud "S3 / MinIO" as s3
cloud "WMS / 1C" as wms
cloud "Payment provider" as pay
cloud "External delivery provider" as deliveryProvider
cloud "Bonus engine" as bonus
cloud "Yandex Metrika" as metrika
cloud "Mindbox" as mindbox
cloud "Hybrid Pixel" as hybrid

[PublicShell] --> [public-content] : HTTP/JSON public content
[Catalog UI] --> [catalog] : HTTP/JSON catalog and products
[Cart UI] --> [cart] : HTTP/JSON cart and offers
[Checkout Delivery UI] --> [delivery] : HTTP/JSON /api/delivery/options, /pickup-points
[Checkout Delivery UI] --> [order] : HTTP/JSON confirm order
[Order Tracking UI] --> [delivery] : HTTP/JSON /shipments/{id}/tracking
[Pickup Owner Cabinet UI] --> [delivery] : HTTP/JSON /pickup-owner/shipments/*
[EmployeeWorkspace UI] --> [employee] : HTTP/JSON employee workspace and support
[AdminOrders UI] --> [admin-order] : HTTP/JSON admin order cards
[AdminService UI] --> [admin-service] : HTTP/JSON service cases and decisions
[AdminPlatform UI] --> [admin-platform] : HTTP/JSON KPI, audit, integrations
[AdminBonus UI] --> [admin-bonus] : HTTP/JSON /api/admin/bonus-program/*
[AdminFulfillment UI] --> [admin-fulfillment] : HTTP/JSON /api/admin/fulfillment/*
[I18nProvider] --> [platform-experience] : HTTP/JSON i18n diagnostics
[NotificationProvider] --> [platform-experience] : HTTP/JSON notification preferences
[OfflineStatusProvider] --> [auth] : HTTP/JSON session check
[AnalyticsProvider] --> [platform-experience] : HTTP/JSON runtime config and consent
[AuthProvider] --> [auth] : HTTP/JSON session/login/logout
[RoleRouter] --> [auth] : HTTP/JSON route access

[auth] --> [authorization] : role, route, MFA and policy checks
[auth] --> [admin-rbac] : session permission matrix
[admin-rbac] --> [authorization] : permission set and scope checks

[cart] --> [catalog] : product and campaign projection
[cart] --> [admin-pricing] : active offers and gifts
[order] --> [cart] : cart snapshot
[order] --> [admin-pricing] : checkout price validation
[order] --> [admin-wms] : reserve and release stock
[order] --> pay : payment protocol
[order] --> [delivery] : shipment creation and tracking links
[order] --> [admin-bonus] : order facts for bonus calculation
[delivery] --> [admin-wms] : stock/delivery constraints and return-to-logistics events
[delivery] --> deliveryProvider : shipment task and status exchange
[delivery] --> [order] : delivery lifecycle events
[delivery] --> [admin-service] : delivery problem and return context
[delivery] --> [admin-platform] : delivery SLA and problem-rate events
[delivery] --> [bonus-wallet] : bonus-affecting delivery outcome events
[delivery] --> [admin-bonus] : delivered, partial and not-collected events
[admin-fulfillment] --> [admin-wms] : HTTP/JSON reserve readiness, return tasks
[admin-fulfillment] --> [order] : HTTP/JSON shipment lifecycle and return events
[admin-fulfillment] --> [admin-order] : HTTP/JSON admin order fulfillment context
[admin-fulfillment] --> [delivery] : HTTP/JSON shipment transfer and tracking sync
[admin-fulfillment] --> deliveryProvider : HTTP/JSON delivery service exchange
[admin-fulfillment] --> [admin-bonus] : HTTP/JSON not-collected, partial and return events
[admin-fulfillment] --> [admin-platform] : HTTP/JSON fulfillment SLA, pickup load, integration health
[admin-fulfillment] --> [admin-identity] : HTTP/JSON pickup owner and operator scope
[employee] --> [delivery] : tracking links and delayed delivery signals
[admin-order] --> [delivery] : shipment reference and delivery blocking context
[admin-service] --> [delivery] : replacement delivery and issue context
[admin-service] --> [admin-bonus] : service compensation and reversal events
[admin-platform] --> [delivery] : delivery integration status and KPI read-model
[admin-bonus] --> [admin-platform] : bonus accruals, payout status and integration health

[admin-wms] --> wms : WMS/1C synchronization
[admin-order] --> pay : payment/refund/dispute protocol
[bonus-wallet] --> bonus : bonus protocol
[admin-bonus] --> bonus : compensation plan and payout exchange
[platform-experience] --> metrika : consent-aware analytics
[platform-experience] --> mindbox : consent-aware marketing
[platform-experience] --> hybrid : consent-aware pixel events

[public-content] --> db
[auth] --> db
[catalog] --> db
[cart] --> db
[order] --> db
[delivery] --> db
[profile] --> db
[bonus-wallet] --> db
[partner-office] --> db
[employee] --> db
[platform-experience] --> db
[admin-rbac] --> db
[admin-cms] --> db
[admin-referral] --> db
[admin-pim] --> db
[admin-catalog] --> db
[admin-pricing] --> db
[admin-wms] --> db
[admin-order] --> db
[admin-service] --> db
[admin-identity] --> db
[admin-platform] --> db
[admin-bonus] --> db
[admin-fulfillment] --> db
[admin-cms] --> s3 : content documents/media metadata
[admin-pim] --> s3 : product media metadata
[admin-service] --> s3 : claim attachments metadata

@enduml
