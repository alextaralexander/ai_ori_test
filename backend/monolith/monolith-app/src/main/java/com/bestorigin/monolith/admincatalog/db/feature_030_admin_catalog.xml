<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="feature-030-admin-catalog-campaigns" author="codex">
        <createTable tableName="admin_catalog_campaign">
            <column name="campaign_id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="campaign_code" type="varchar(64)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="name" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="locale_code" type="varchar(16)">
                <constraints nullable="false"/>
            </column>
            <column name="audience" type="varchar(64)">
                <constraints nullable="false"/>
            </column>
            <column name="starts_at" type="timestamp with time zone"/>
            <column name="ends_at" type="timestamp with time zone"/>
            <column name="status" type="varchar(32)">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="uuid"/>
            <column name="updated_at" type="timestamp with time zone"/>
        </createTable>
        <createTable tableName="admin_catalog_issue">
            <column name="issue_id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="campaign_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="issue_code" type="varchar(64)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="status" type="varchar(32)">
                <constraints nullable="false"/>
            </column>
            <column name="current_flag" type="boolean" defaultValueBoolean="false"/>
            <column name="next_flag" type="boolean" defaultValueBoolean="false"/>
            <column name="archive_flag" type="boolean" defaultValueBoolean="false"/>
            <column name="publication_at" type="timestamp with time zone"/>
            <column name="archive_at" type="timestamp with time zone"/>
            <column name="freeze_starts_at" type="timestamp with time zone"/>
            <column name="rollover_window_starts_at" type="timestamp with time zone"/>
            <column name="rollover_window_ends_at" type="timestamp with time zone"/>
        </createTable>
        <createTable tableName="admin_catalog_material">
            <column name="material_id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="issue_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="material_type" type="varchar(32)">
                <constraints nullable="false"/>
            </column>
            <column name="file_name" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="mime_type" type="varchar(128)">
                <constraints nullable="false"/>
            </column>
            <column name="size_bytes" type="bigint"/>
            <column name="checksum" type="varchar(128)">
                <constraints nullable="false"/>
            </column>
            <column name="storage_key" type="varchar(512)"/>
            <column name="version" type="int" defaultValueNumeric="1"/>
            <column name="status" type="varchar(32)">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createTable tableName="admin_catalog_page">
            <column name="page_id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="issue_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="page_number" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="image_url" type="varchar(512)"/>
            <column name="width_px" type="int"/>
            <column name="height_px" type="int"/>
            <column name="status" type="varchar(32)">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createTable tableName="admin_catalog_hotspot">
            <column name="hotspot_id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="issue_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="page_number" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="product_id" type="uuid"/>
            <column name="sku" type="varchar(128)">
                <constraints nullable="false"/>
            </column>
            <column name="promo_code" type="varchar(128)"/>
            <column name="x_ratio" type="numeric(6,5)"/>
            <column name="y_ratio" type="numeric(6,5)"/>
            <column name="width_ratio" type="numeric(6,5)"/>
            <column name="height_ratio" type="numeric(6,5)"/>
            <column name="sort_order" type="int" defaultValueNumeric="0"/>
            <column name="status" type="varchar(32)">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createTable tableName="admin_catalog_rollover_job">
            <column name="rollover_job_id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="idempotency_key" type="varchar(128)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="source_issue_id" type="uuid"/>
            <column name="target_issue_id" type="uuid"/>
            <column name="status" type="varchar(32)">
                <constraints nullable="false"/>
            </column>
            <column name="message_code" type="varchar(128)"/>
            <column name="created_at" type="timestamp with time zone"/>
        </createTable>
        <createTable tableName="admin_catalog_audit_event">
            <column name="audit_event_id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="entity_type" type="varchar(64)">
                <constraints nullable="false"/>
            </column>
            <column name="entity_id" type="uuid"/>
            <column name="action_code" type="varchar(96)">
                <constraints nullable="false"/>
            </column>
            <column name="actor_user_id" type="uuid"/>
            <column name="old_value" type="jsonb"/>
            <column name="new_value" type="jsonb"/>
            <column name="correlation_id" type="varchar(128)"/>
            <column name="occurred_at" type="timestamp with time zone"/>
        </createTable>
        <createIndex tableName="admin_catalog_page" indexName="idx_admin_catalog_page_issue_number">
            <column name="issue_id"/>
            <column name="page_number"/>
        </createIndex>
        <createIndex tableName="admin_catalog_hotspot" indexName="idx_admin_catalog_hotspot_issue_sku">
            <column name="issue_id"/>
            <column name="sku"/>
        </createIndex>
        <createIndex tableName="admin_catalog_audit_event" indexName="idx_admin_catalog_audit_action_correlation">
            <column name="action_code"/>
            <column name="correlation_id"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
