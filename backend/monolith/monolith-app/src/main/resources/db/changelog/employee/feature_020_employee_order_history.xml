<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="feature-020-employee-order-history-snapshot" author="codex">
        <createTable tableName="employee_order_history_snapshot">
            <column name="order_id" type="varchar(64)">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_employee_order_history_snapshot"/>
            </column>
            <column name="order_number" type="varchar(64)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uk_employee_order_history_order_number"/>
            </column>
            <column name="campaign_code" type="varchar(32)"/>
            <column name="customer_id" type="varchar(64)"/>
            <column name="partner_id" type="varchar(64)"/>
            <column name="customer_display_name" type="varchar(255)"/>
            <column name="partner_display_name" type="varchar(255)"/>
            <column name="masked_phone" type="varchar(64)"/>
            <column name="masked_email" type="varchar(255)"/>
            <column name="order_status" type="varchar(32)"/>
            <column name="payment_status" type="varchar(32)"/>
            <column name="delivery_status" type="varchar(32)"/>
            <column name="fulfillment_status" type="varchar(32)"/>
            <column name="total_amount" type="numeric(19,2)"/>
            <column name="currency_code" type="varchar(3)"/>
            <column name="problem_flags_json" type="jsonb"/>
            <column name="support_case_ids_json" type="jsonb"/>
            <column name="claim_ids_json" type="jsonb"/>
            <column name="payment_event_ids_json" type="jsonb"/>
            <column name="wms_batch_id" type="varchar(64)"/>
            <column name="delivery_tracking_id" type="varchar(128)"/>
            <column name="manual_adjustment_present" type="boolean" defaultValueBoolean="false"/>
            <column name="supervisor_required" type="boolean" defaultValueBoolean="false"/>
            <column name="source_channel" type="varchar(64)"/>
            <column name="created_at" type="timestamp with time zone"/>
            <column name="updated_at" type="timestamp with time zone"/>
        </createTable>
        <createIndex tableName="employee_order_history_snapshot" indexName="idx_employee_order_history_customer">
            <column name="customer_id"/>
        </createIndex>
        <createIndex tableName="employee_order_history_snapshot" indexName="idx_employee_order_history_partner">
            <column name="partner_id"/>
        </createIndex>
        <createIndex tableName="employee_order_history_snapshot" indexName="idx_employee_order_history_updated_at">
            <column name="updated_at"/>
        </createIndex>
    </changeSet>

    <changeSet id="feature-020-employee-order-history-items" author="codex">
        <createTable tableName="employee_order_history_item_snapshot">
            <column name="item_id" type="uuid">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_employee_order_history_item"/>
            </column>
            <column name="order_id" type="varchar(64)">
                <constraints nullable="false" foreignKeyName="fk_employee_order_history_item_order" references="employee_order_history_snapshot(order_id)" deleteCascade="true"/>
            </column>
            <column name="sku" type="varchar(64)"/>
            <column name="product_name" type="varchar(255)"/>
            <column name="quantity" type="int"/>
            <column name="unit_price" type="numeric(19,2)"/>
            <column name="total_price" type="numeric(19,2)"/>
            <column name="promo_code" type="varchar(64)"/>
            <column name="bonus_points" type="int"/>
            <column name="reserve_status" type="varchar(32)"/>
        </createTable>
        <addCheckConstraint tableName="employee_order_history_item_snapshot" constraintName="chk_employee_order_history_item_qty" checkConstraint="quantity &gt; 0"/>
        <createIndex tableName="employee_order_history_item_snapshot" indexName="idx_employee_order_history_item_order">
            <column name="order_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="feature-020-employee-order-history-audit" author="codex">
        <createTable tableName="employee_order_history_audit_event">
            <column name="audit_event_id" type="uuid">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_employee_order_history_audit"/>
            </column>
            <column name="order_id" type="varchar(64)">
                <constraints nullable="false" foreignKeyName="fk_employee_order_history_audit_order" references="employee_order_history_snapshot(order_id)" deleteCascade="true"/>
            </column>
            <column name="actor_user_id" type="varchar(64)"/>
            <column name="actor_role" type="varchar(64)"/>
            <column name="action_type" type="varchar(64)"/>
            <column name="support_reason_code" type="varchar(64)"/>
            <column name="source_route" type="varchar(255)"/>
            <column name="metadata_json" type="jsonb"/>
            <column name="occurred_at" type="timestamp with time zone"/>
        </createTable>
        <createIndex tableName="employee_order_history_audit_event" indexName="idx_employee_order_history_audit_order">
            <column name="order_id"/>
        </createIndex>
        <createIndex tableName="employee_order_history_audit_event" indexName="idx_employee_order_history_audit_actor">
            <column name="actor_user_id"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
